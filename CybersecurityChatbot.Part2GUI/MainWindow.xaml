<Window x:Class="CybersecurityChatbot.Part2GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rofhiwa CyberSafe Companion - Part 3 POE"
        Height="760" Width="1220" MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen" Background="#0F172A"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/><Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="#38BDF8"/><Setter Property="Foreground" Value="#06111F"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Padding" Value="10,0"/>
        </Style>
        <Style x:Key="ChatBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/><Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="8,6"/><Setter Property="MaxWidth" Value="620"/>
            <Setter Property="HorizontalAlignment" Value="Left"/><Setter Property="Background" Value="#E0F2FE"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#172235" CornerRadius="18" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ROFHIWA CYBERSAFE" Foreground="#7DD3FC" FontSize="23" FontWeight="Bold" TextAlignment="Center"/>
                    <TextBlock Text="Companion POE" Foreground="White" FontSize="19" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,12"/>
                    <Border Background="#0B1220" CornerRadius="12" Padding="10" Margin="0,0,0,12">
                        <TextBlock x:Name="AsciiTextBlock" Foreground="#22C55E" FontFamily="Consolas" FontSize="8" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Text="Your Name" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="NameTextBox" Height="42" FontSize="15" Padding="10,0" VerticalContentAlignment="Center" Background="White" Foreground="#0F172A" BorderBrush="#38BDF8" BorderThickness="2" KeyDown="NameTextBox_KeyDown"/>
                    <Button Content="Save My Name" Style="{StaticResource ActionButtonStyle}" Margin="0,10,0,14" Click="SaveNameButton_Click"/>
                    <TextBlock Text="Asking Tips" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="#0B1220" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                        <TextBlock Foreground="#CBD5E1" TextWrapping="Wrap" LineHeight="21"
                                   Text="• Start quiz / play mini game&#x0a;• Add task to enable 2FA&#x0a;• Remind me to update password tomorrow&#x0a;• Show activity log&#x0a;• What have you done for me?&#x0a;• Give me a phishing tip&#x0a;• I am worried about scams&#x0a;• Tell me more / another tip"/>
                    </Border>
                    <Button Content="Show Help Topics" Style="{StaticResource ActionButtonStyle}" Click="HelpButton_Click"/>
                    <Button Content="Clear Chat" Style="{StaticResource ActionButtonStyle}" Background="#F8FAFC" Click="ClearButton_Click"/>
                    <Border Background="#0B1220" CornerRadius="12" Padding="12" Margin="0,8,0,0">
                        <TextBlock x:Name="MemoryTextBlock" Foreground="#E2E8F0" TextWrapping="Wrap" LineHeight="20"/>
                    </Border>
                    <Border Background="#0B1220" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <TextBlock x:Name="DatabaseStatusTextBlock" Foreground="#FDE68A" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Column="2" Background="#E5EEF8" CornerRadius="18" Padding="16">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Chat">
                    <Grid Margin="0,10,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,10"><TextBlock Text="Rofhiwa CyberSafe Companion" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="Cybersecurity chat, task reminders, quiz practice, NLP commands and activity tracking." Foreground="#334155" FontSize="14"/></StackPanel>
                        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="10"><ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"><ItemsControl x:Name="ChatItemsControl"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource ChatBubbleStyle}"><StackPanel><DockPanel LastChildFill="True" Margin="0,0,0,4"><TextBlock Text="{Binding Sender}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" DockPanel.Dock="Left"/><TextBlock Text="{Binding Time}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/></DockPanel><TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="15" Foreground="#0F172A" LineHeight="22"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                        <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="135"/></Grid.ColumnDefinitions><TextBox x:Name="UserInputTextBox" Grid.Column="0" Height="46" FontSize="15" Padding="12,0" VerticalContentAlignment="Center" Background="White" Foreground="#0F172A" BorderBrush="#38BDF8" BorderThickness="2" KeyDown="UserInputTextBox_KeyDown"/><Button Grid.Column="2" Content="Send" Height="46" Background="#0EA5E9" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="SendButton_Click"/></Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Task Assistant">
                    <Grid Margin="0,12,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Background="White" CornerRadius="14" Padding="14" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" Margin="0,0,10,0"><TextBlock Text="Task title" FontWeight="Bold"/><TextBox x:Name="TaskTitleTextBox" Height="36" Padding="8,0" VerticalContentAlignment="Center"/></StackPanel><StackPanel Grid.Column="1" Margin="0,0,10,0"><TextBlock Text="Description" FontWeight="Bold"/><TextBox x:Name="TaskDescriptionTextBox" Height="36" Padding="8,0" VerticalContentAlignment="Center"/></StackPanel><StackPanel Grid.Column="2" Margin="0,0,10,0"><TextBlock Text="Reminder date" FontWeight="Bold"/><DatePicker x:Name="ReminderDatePicker" Height="36"/></StackPanel><Button Grid.Column="3" Content="Add Task" Height="36" Margin="0,18,0,0" Background="#0EA5E9" Foreground="White" BorderThickness="0" Click="AddTaskButton_Click"/></Grid></Border>
                        <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Background="White"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/><DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/><DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDisplay}" Width="160"/><DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="110"/></DataGrid.Columns></DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><TextBlock Text="Task ID:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,6,0"/><TextBox x:Name="TaskIdTextBox" Width="80" Height="38" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,8,0" ToolTip="Type the task ID from the table, then click Complete or Delete."/><Button Content="Refresh" Width="110" Height="38" Margin="0,0,8,0" Click="RefreshTasksButton_Click"/><Button Content="Mark Completed" Width="140" Height="38" Margin="0,0,8,0" Click="CompleteTaskButton_Click"/><Button Content="Delete Task" Width="120" Height="38" Click="DeleteTaskButton_Click"/></StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Quiz Mini-Game">
                    <Border Margin="0,12,0,0" Background="White" CornerRadius="16" Padding="18"><StackPanel><TextBlock Text="Cybersecurity Mini-Game" FontSize="24" FontWeight="Bold"/><TextBlock x:Name="QuizStatusTextBlock" Text="Press Start Quiz to begin." Margin="0,8,0,10" TextWrapping="Wrap"/><TextBlock x:Name="QuizQuestionTextBlock" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10"/><StackPanel x:Name="QuizOptionsPanel"/><Button Content="Start Quiz" Width="130" Height="40" HorizontalAlignment="Left" Margin="0,12,0,0" Background="#0EA5E9" Foreground="White" BorderThickness="0" Click="StartQuizButton_Click"/></StackPanel></Border>
                </TabItem>
                <TabItem Header="Activity Log">
                    <Border Margin="0,12,0,0" Background="White" CornerRadius="16" Padding="18"><StackPanel><TextBlock Text="Recent Chatbot Actions" FontSize="24" FontWeight="Bold"/><TextBlock Text="The log records tasks, reminders, quiz attempts and NLP commands." Foreground="#475569" Margin="0,0,0,10"/><TextBox x:Name="ActivityLogTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="430" FontFamily="Consolas" FontSize="14"/><Button Content="Refresh Activity Log" Width="170" Height="38" HorizontalAlignment="Right" Margin="0,12,0,0" Click="RefreshLogButton_Click"/></StackPanel></Border>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
